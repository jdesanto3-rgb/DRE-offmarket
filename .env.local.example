NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CRON_SECRET=your-cron-secret
# Livingston County ArcGIS Online credentials (livgov.maps.arcgis.com)
# Note: county private service requires org credentials — not used for Howell/Brighton
ARCGIS_USERNAME=your-arcgis-username
ARCGIS_PASSWORD=your-arcgis-password

# Regrid API — used for Howell + Brighton parcel data
# Sign up at https://app.regrid.com/api — Basic plan covers bulk city queries
REGRID_API_TOKEN=your-regrid-api-token
